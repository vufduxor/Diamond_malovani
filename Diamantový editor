            <p>Klikněte nebo přetáhněte obrázek</p>
            <p style="font-size:11px">JPG · PNG · WEBP</p>
            <input type="file" id="file-input" accept="image/*" style="display:none">
        </div>
        <img id="preview-img" alt="náhled">
    </div>

    <div class="panel" style="flex:1;min-width:210px;display:flex;flex-direction:column;gap:14px">
        <div><div class="section-title">Orientace formátu A4</div><div class="seg"><div class="seg-btn active" id="o-portrait" onclick="setOrient('portrait')">Na výšku</div><div class="seg-btn" id="o-landscape" onclick="setOrient('landscape')">Na šířku</div></div><div class="orient-preview"><div class="orient-box active" id="prev-portrait" style="width:22px;height:31px"></div><div style="font-size:10px;color:#888;line-height:1.5" id="orient-info">75 × 106<br>kamínků</div><div class="orient-box" id="prev-landscape" style="width:31px;height:22px"></div></div></div>
        <div><div class="section-title">Přizpůsobení obrázku</div><div class="seg"><div class="seg-btn active" id="fit-fill" onclick="setFit('fill')">Vyplnit vše</div><div class="seg-btn" id="fit-contain" onclick="setFit('contain')">Vejít se celý</div></div></div>
        <div><div class="section-title">Velikost kamínku</div><div class="diamond-size-row"><label>Průměr:</label><input type="number" id="diamond-size" value="2.8" min="1.0" max="10.0" step="0.1" onchange="updateDiamondSize()"><span style="font-size:11px;color:#888">mm (1,0 – 10,0)</span></div><div class="grid-info" id="grid-info">Mřížka: 75 × 106 = 7 950 kamínků</div></div>
        <div><div class="section-title">Paleta barev</div><div class="toggle-row"><label class="toggle-switch"><input type="checkbox" id="use-custom-palette" onchange="togglePaletteMode()"><span class="toggle-slider"></span></label><span style="font-size:11px;color:#999">Použít vlastní DMC paletu</span></div><div id="custom-palette-section" class="hidden" style="margin-top:8px"><textarea id="palette-input" placeholder="#d5d4d2,1&#10;#c7c9cd,2&#10;..."></textarea><div style="display:flex;gap:6px;margin-top:4px"><button class="btn btn-small" onclick="loadPaletteFromInput()">Načíst z textu</button><button class="btn btn-small" onclick="loadDefaultPalette()">Výchozí DMC</button></div></div><div style="margin-top:6px"><input type="file" id="palette-file-input" accept=".txt,.csv" style="font-size:11px;color:#999" onchange="loadPaletteFile(this)"></div><div class="palette-info" style="margin-top:4px" id="active-palette-info">Aktivní: <strong>Výchozí DMC (447 barev)</strong></div></div>
        <div><div class="section-title">Počet barev <span style="font-size:10px;color:#888">(0 = automaticky)</span></div><div class="range-row"><input type="range" id="color-count" min="0" max="100" value="15" step="1" style="flex:1"><span class="range-val" id="color-count-val">15</span></div></div>
        <button class="btn btn-primary" id="process-btn" style="width:100%" disabled>Vygenerovat mřížku</button>
        <button class="btn btn-small" id="change-image-btn" style="width:100%;margin-top:4px" onclick="changeImage()">Změnit obrázek</button>
        <div id="progress-wrap" class="hidden"><div style="font-size:11px;color:#888;margin-bottom:4px" id="progress-label">Zpracovávám...</div><progress id="prog" value="0" max="100"></progress></div>
    </div>
</div>

<div id="result-section" class="hidden">
