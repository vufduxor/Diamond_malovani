    <div class="toolbar"><div class="section-title" style="margin:0" id="grid-title">Mřížka 75 × 106</div><div style="flex:1"></div><button class="btn btn-xs" id="zoom-out" title="Oddálit">−</button><span id="zoom-label" style="font-size:11px;color:#888;min-width:30px;text-align:center">4px</span><button class="btn btn-xs" id="zoom-in" title="Přiblížit">+</button><button class="btn btn-xs" id="btn-fit" onclick="fitGrid()" title="Přizpůsobit oknu">⬜</button><div class="export-btns"><button class="btn btn-primary btn-small" id="download-grid-btn">PNG 300 DPI</button><button class="btn btn-success btn-small" id="download-pdf-btn">PDF A4 (2 strany)</button><button class="btn btn-small" id="download-legend-btn">Legenda PNG</button></div></div>

    <div id="grid-wrapper"><canvas id="grid-canvas"></canvas></div>
    <div class="status-bar"><span><span class="status-dot off" id="edit-indicator"></span> <span id="edit-status">Editor vypnutý</span></span><span id="cursor-info">Připraveno</span><span id="edit-count" style="display:none">Změněno: 0 čtverečků</span></div>

