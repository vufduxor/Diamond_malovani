// ==================== PŮVODNÍ ALGORITMUS PRO ČTENÍ BAREV ====================
function colorDistance(c1,c2){var r1=c1[0]||c1.r,g1=c1[1]||c1.g,b1=c1[2]||c1.b,r2=c2[0]||c2.r,g2=c2[1]||c2.g,b2=c2[2]||c2.b,rmean=(r1+r2)/2;return(2+Math.abs(rmean)/256)*(r1-r2)*(r1-r2)+4*(g1-g2)*(g1-g2)+(2+(255-Math.abs(rmean))/256)*(b1-b2)*(b1-b2);}
function isGrayish(rgb){var r=rgb[0]||rgb.r,g=rgb[1]||rgb.g,b=rgb[2]||rgb.b,max=Math.max(r,g,b),min=Math.min(r,g,b);if(max===0)return true;return(max-min)/max<0.10;}
function isVeryDark(rgb){var r=rgb[0]||rgb.r,g=rgb[1]||rgb.g,b=rgb[2]||rgb.b;return(r+g+b)/3<20;}
function isVeryLight(rgb){var r=rgb[0]||rgb.r,g=rgb[1]||rgb.g,b=rgb[2]||rgb.b;return(r+g+b)/3>240;}
function findClosestGray(rgb,pal){var grays=[];for(var i=0;i<pal.length;i++)if(isGrayish(pal[i].rgb))grays.push(pal[i]);if(grays.length===0)return findClosestInPaletteRaw(rgb,pal);var best=0,bestD=Infinity;for(var i=0;i<grays.length;i++){var d=colorDistance(rgb,grays[i].rgb);if(d<bestD){bestD=d;best=i;}}return grays[best];}
function findClosestInPaletteRaw(rgb,pal){if(!pal||pal.length===0)return null;var best=0,bestD=Infinity;for(var i=0;i<pal.length;i++){var d=colorDistance(rgb,pal[i].rgb);if(d<bestD){bestD=d;best=i;}}return pal[best];}
function findClosestInPalette(rgb,pal){if(!pal||pal.length===0)return null;if(isVeryDark(rgb)){for(var i=0;i<pal.length;i++)if(pal[i].rgb[0]<=5&&pal[i].rgb[1]<=5&&pal[i].rgb[2]<=5)return pal[i];}if(isVeryLight(rgb)){for(var i=0;i<pal.length;i++)if(pal[i].rgb[0]>=250&&pal[i].rgb[1]>=250&&pal[i].rgb[2]>=250)return pal[i];}if(isGrayish(rgb))return findClosestGray(rgb,pal);var best=0,bestD=Infinity;for(var i=0;i<pal.length;i++){var d=colorDistance(rgb,pal[i].rgb);if(isGrayish(pal[i].rgb)&&!isGrayish(rgb))d*=2.5;if(d<bestD){bestD=d;best=i;}}return pal[best];}

function parsePaletteText(text){var lines=text.split(/[\n\r]+/).filter(function(l){return l.trim().length>0}),result=[];for(var i=0;i<lines.length;i++){var parts=lines[i].split(',');if(parts.length>=2){var hex=parts[0].trim().toLowerCase(),code=parts[1].trim();if(hex.match(/^#[0-9a-f]{6}$/))result.push({hex:hex,code:code});}}return result;}
