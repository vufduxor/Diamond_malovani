  }
};

// ==================== LEGENDA PNG ====================
document.getElementById('download-legend-btn').onclick=function(){
  if(!gridData)return;var TOTAL=COLS*ROWS,counts=[];for(var i=0;i<palette.length;i++)counts.push(0);for(var i=0;i<gridData.length;i++)counts[gridData[i]]++;var rows=[];for(var i=0;i<palette.length;i++)rows.push({n:(i+1),dmc:palette[i].dmc,hex:toHex(palette[i]),cnt:counts[i],pct:((counts[i]/TOTAL)*100).toFixed(1)});rows.sort(function(a,b){return b.cnt-a.cnt;});
  var W=1600,H=180+rows.length*36+180,big=document.createElement('canvas');big.width=W;big.height=H;var ctx=big.getContext('2d');
  ctx.fillStyle='#0d0d0d';ctx.fillRect(0,0,W,H);ctx.fillStyle='#fff';ctx.font='bold 28px system-ui,sans-serif';ctx.fillText('Legenda a spotřeba kamínků  •  BY Vufdux',35,50);
  ctx.font='16px system-ui,sans-serif';ctx.fillStyle='#999';ctx.fillText('A4 '+(orientMode==='portrait'?'na výšku':'na šířku')+' · '+COLS+'×'+ROWS+' = '+TOTAL.toLocaleString()+' kamínků · '+palette.length+' DMC barev · '+DIAMOND_MM.toFixed(1)+' mm',35,80);
  var y=120,colX=[35,80,160,210,350,470,550],hdrs=['Č.','DMC','','HEX','Kusů','%'];
  ctx.fillStyle='#fff';ctx.font='bold 18px system-ui,sans-serif';hdrs.forEach(function(h,i){ctx.textAlign=(i>=4)?'right':'left';ctx.fillText(h,colX[i],y);});
  ctx.strokeStyle='#444';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(35,y+8);ctx.lineTo(W-35,y+8);ctx.stroke();y+=28;
  rows.forEach(function(r){ctx.fillStyle='#fff';ctx.font='bold 17px monospace';ctx.textAlign='right';ctx.fillText(r.n,colX[0]+25,y+2);ctx.textAlign='left';ctx.fillText(r.dmc,colX[1],y+2);ctx.fillStyle=r.hex;ctx.fillRect(colX[2],y-12,24,24);ctx.strokeStyle='#444';ctx.lineWidth=2;ctx.strokeRect(colX[2],y-12,24,24);ctx.fillStyle='#ccc';ctx.font='16px monospace';ctx.fillText(r.hex.toUpperCase(),colX[3],y+2);ctx.textAlign='right';ctx.fillStyle='#fff';ctx.fillText(r.cnt.toLocaleString()+' ks',colX[4]+70,y+2);ctx.fillStyle='#888';ctx.fillText(r.pct+' %',colX[5]+50,y+2);y+=34;});
  y+=30;ctx.fillStyle='#fff';ctx.font='bold 18px system-ui,sans-serif';ctx.textAlign='left';ctx.fillText('Celkem: '+TOTAL.toLocaleString()+' kamínků  |  '+palette.length+' DMC barev',35,y);y+=25;ctx.fillStyle='#666';ctx.font='italic 14px system-ui,sans-serif';ctx.fillText('BY Vufdux  •  Diamantové malování – Návrhář předloh',35,y);
  var link=document.createElement('a');link.download='diamond-painting-legend-'+orientMode+'-'+DIAMOND_MM.toFixed(1)+'mm.png';link.href=big.toDataURL('image/png');document.body.appendChild(link);link.click();document.body.removeChild(link);
};
