function detectColors(pixels,maxColors,paletteRef){
  var histo={};for(var i=0;i<pixels.length;i++){var p=pixels[i],weight=1,col=Math.floor(i%COLS),row=Math.floor(i/COLS);if(col<2||col>=COLS-2||row<2||row>=ROWS-2)weight=2;var r=Math.round(p[0]/8)*8,g=Math.round(p[1]/8)*8,b=Math.round(p[2]/8)*8,key=r+','+g+','+b;if(!histo[key])histo[key]={r:r,g:g,b:b,count:0};histo[key].count+=weight;}
  var colors=[];for(var k in histo)colors.push(histo[k]);colors.sort(function(a,b){return b.count-a.count;});
  var extracted=[],minDist=15;for(var i=0;i<colors.length&&extracted.length<maxColors*3;i++){var tooClose=false,crgb=[colors[i].r,colors[i].g,colors[i].b];for(var j=0;j<extracted.length;j++)if(colorDistance(crgb,extracted[j])<minDist*minDist){tooClose=true;break;}if(!tooClose)extracted.push(crgb);}
